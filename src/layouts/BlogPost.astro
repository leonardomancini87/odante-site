---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import AuthorLink from '../components/AuthorLink.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { url } from '../utils/paths';
import { marked } from 'marked';

type Props = CollectionEntry<'blog'>['data'] & {
	id?: string;
	headings?: { depth: number; slug: string; text: string }[];
	toc?: boolean;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	featuredImage,
	authors,
	tags,
	id,
	headings = [],
	toc,
	criticalNote,
	criticalNoteAuthor,
	criticalNoteDate,
} = Astro.props;

const mainImage = heroImage || featuredImage;
const criticalNoteHtml = criticalNote ? marked.parse(criticalNote) : '';
---

<html lang="it">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			html {
				scroll-padding-top: 5.5rem;
			}

			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding-top: 0.5rem;
			}

			.hero-image {
				width: calc(100% - 4rem);
				max-width: 1080px;
				margin: 1.75rem auto 0.75rem auto;
				overflow: hidden;
				border-radius: 28px;
				position: relative;
				box-shadow: var(--shadow-lg);
				background: var(--color-bg-offset);
			}

			.hero-image img {
				width: 100%;
				height: auto;
				display: block;
			}

			.blog-container {
				position: relative;
				max-width: 1200px;
				margin: 0 auto;
				display: flex;
				justify-content: center;
			}

			.prose-wrapper {
				position: relative;
				width: 760px;
				max-width: 100%;
			}

			.prose {
				width: 100%;
				padding: 1rem;
				color: var(--color-text-main);
			}

			.prose :global(p) {
				text-align: justify;
				hyphens: auto;
			}

			.title {
				margin-bottom: 0.5em;
				padding: 0.25em 0 0.5em 0;
				text-align: center;
				line-height: 1.2;
			}

			.title h1 {
				margin: 0 0 0.5em 0;
				font-size: 2.2rem;
			}

			.date {
				margin-bottom: 0.5em;
				color: var(--color-text-muted);
			}

			.last-updated-on {
				font-style: italic;
			}

			.blog-authors {
				display: flex;
				gap: 0.5rem;
				justify-content: center;
				flex-wrap: wrap;
				margin-top: 0.75rem;
				font-size: 0.9rem;
				color: var(--color-text-muted);
			}

			.blog-authors span {
				font-size: 0.9rem;
			}

			.prose :global(ul),
			.prose :global(ol) {
				margin: 0 0 1.5rem;
				padding-left: 1.5rem;
			}

			.prose :global(li) {
				margin: 0.45rem 0;
			}

			.prose :global(li > p) {
				margin-bottom: 0.75rem;
			}

			.prose :global(blockquote) {
				position: relative;
				margin: 2.25rem 0;
				padding: 1.3rem 3.25rem;
				border: 1px solid var(--color-border);
				border-left: 4px solid var(--color-accent);
				background:
					linear-gradient(135deg, var(--color-accent-light) 0%, transparent 100%),
					var(--color-bg-offset);
				border-radius: 18px;
				box-shadow: var(--shadow-sm);
				overflow: hidden;
				quotes: '"' '"' "'" "'";
			}

			.prose :global(blockquote::before) {
				content: open-quote;
				position: absolute;
				top: 0.35rem;
				left: 0.95rem;
				font-family: var(--font-serif);
				font-size: 4rem;
				line-height: 1;
				color: var(--color-accent);
				opacity: 0.22;
			}

			.prose :global(blockquote::after) {
				content: close-quote;
				position: absolute;
				right: 0.95rem;
				bottom: -0.45rem;
				font-family: var(--font-serif);
				font-size: 4rem;
				line-height: 1;
				color: var(--color-accent);
				opacity: 0.18;
			}

			.prose :global(blockquote p) {
				margin: 0.3rem 0;
				color: var(--color-text-main);
				text-align: left;
				font-size: 1.02rem;
			}

			.prose :global(hr) {
				margin: 2rem 0;
				border: 0;
				border-top: 1px solid var(--color-border);
			}

			.prose :global(code) {
				font-family: ui-monospace, SFMono-Regular, Consolas, 'Liberation Mono', Menlo, monospace;
				font-size: 0.92em;
				background: var(--color-accent-light);
				padding: 0.15rem 0.35rem;
				border-radius: 0.35rem;
			}

			.prose :global(pre) {
				margin: 1.75rem 0;
				overflow-x: auto;
				line-height: 1.1;
			}

			.prose :global(pre code) {
				display: block;
				background: transparent;
				padding: 0;
				border-radius: 0;
				font-size: 0.88rem;
				line-height: 1.5 !important;
			}

			.prose :global(table) {
				width: 100%;
				margin: 2rem 0;
				border-collapse: collapse;
				display: block;
				overflow-x: auto;
				font-size: 0.95rem;
			}

			.prose :global(th),
			.prose :global(td) {
				padding: 0.75rem 1rem;
				border: 1px solid var(--color-border);
				text-align: left;
			}

			.prose :global(th) {
				background: var(--color-accent-light);
				color: var(--color-text-main);
			}

			.prose :global(img) {
				max-width: 100%;
				height: auto;
				border-radius: 12px;
				box-shadow: var(--shadow-sm);
			}

			.critical-note-box {
				margin: 2.25rem 0 1rem;
				padding: 1.1rem 0;
				border-top: 1px solid var(--color-border);
				border-bottom: 1px solid var(--color-border);
				background: transparent;
				text-align: left;
			}

			.critical-note-box::before {
				content: "Approfondimento";
				display: block;
				margin-bottom: 0.35rem;
				font-size: 0.72rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--color-text-muted);
			}

			.critical-note-button {
				background: none;
				color: var(--color-accent);
				border: none;
				padding: 0;
				font-family: var(--font-serif);
				font-size: 1.15rem;
				font-weight: 500;
				cursor: pointer;
				text-decoration: none;
			}

			.critical-note-button:hover {
				opacity: 0.75;
				text-decoration: underline;
				text-underline-offset: 0.25em;
			}

			.critical-note-modal {
				position: fixed;
				inset: 0;
				background: rgba(0, 0, 0, 0.6);
				display: none;
				align-items: center;
				justify-content: center;
				z-index: 9999;
				padding: 2rem;
			}

			.critical-note-modal.active {
				display: flex;
			}

			.critical-note-content {
				background: var(--color-bg);
				color: var(--color-text-main);
				max-width: 720px;
				width: 100%;
				max-height: 80vh;
				overflow-y: auto;
				padding: 2rem;
				border-radius: 24px;
				position: relative;
				box-shadow: var(--shadow-lg);
			}

			.critical-note-close {
				position: absolute;
				top: 1rem;
				right: 1rem;
				background: none;
				border: none;
				font-size: 2rem;
				cursor: pointer;
				color: var(--color-text-main);
			}

			@media (max-width: 768px) {
				.title h1 {
					font-size: 1.6rem;
				}

				.prose {
					padding: 1rem 0.5rem;
				}

				.hero-image {
					width: calc(100% - 1rem);
					margin: 0.75rem auto 2rem auto;
					border-radius: 20px;
				}
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<article>
				{mainImage && (
					<div class="hero-image">
						<img src={mainImage} alt={title} />
					</div>
				)}

				<div class="blog-container">
					<div class="prose-wrapper">
						<div class="prose">
							<div class="title">
								{pubDate && (
									<div class="date">
										<FormattedDate date={pubDate} />

										{updatedDate && (
											<div class="last-updated-on">
												Last updated on <FormattedDate date={updatedDate} />
											</div>
										)}
									</div>
								)}

								<h1>{title}</h1>

								{authors && authors.length > 0 && (
									<div class="blog-authors">
										{authors.map((authorId, i) => (
											<span>
												<AuthorLink nameOrSlug={authorId} />
												{i < authors.length - 1 ? ', ' : ''}
											</span>
										))}
									</div>
								)}

								{tags && tags.length > 0 && (
									<div
										class="blog-tags"
										style="display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap; margin-top: 0.75rem;"
									>
										{tags.map((tag) => (
											<a
												href={url(`/tags/${tag}`)}
												style="text-decoration: none; font-size: 0.85rem; font-weight: 600; color: var(--color-accent); background: var(--color-bg-offset); padding: 0.2rem 0.6rem; border-radius: 999px; border: 1px solid var(--color-border);"
											>
												#{tag}
											</a>
										))}
									</div>
								)}

								<hr />
							</div>

							{toc !== false && headings.length > 0 && (
								<>
									<TableOfContents headings={headings} mobile={true} />
									<TableOfContents headings={headings} mobile={false} />
								</>
							)}

							<slot />

							{criticalNote && (
								<div class="critical-note-box">
									<button class="critical-note-button" type="button" data-critical-note-open>
										↳ Approfondimento
									</button>
								</div>
							)}

							{criticalNote && (
								<div class="critical-note-modal" data-critical-note-modal>
									<div class="critical-note-content">
										<button
											class="critical-note-close"
											type="button"
											data-critical-note-close
										>
											×
										</button>

										<h2>Approfondimento</h2>

										{criticalNoteAuthor && (
											<p><strong>{criticalNoteAuthor}</strong></p>
										)}

										{criticalNoteDate && (
											<p class="critical-note-date">
												Data di pubblicazione: {criticalNoteDate}
											</p>
										)}

										<div class="critical-note-text" set:html={criticalNoteHtml} />
									</div>
								</div>
							)}
						</div>
					</div>
				</div>
			</article>
		</main>

		<Footer />

		<script is:inline>
			const openButton = document.querySelector('[data-critical-note-open]');
			const modal = document.querySelector('[data-critical-note-modal]');
			const closeButton = document.querySelector('[data-critical-note-close]');

			if (openButton && modal && closeButton) {
				openButton.addEventListener('click', () => {
					modal.classList.add('active');
				});

				closeButton.addEventListener('click', () => {
					modal.classList.remove('active');
				});

				modal.addEventListener('click', (event) => {
					if (event.target === modal) {
						modal.classList.remove('active');
					}
				});
			}
		</script>
	</body>
</html>