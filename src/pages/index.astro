---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { url } from '../utils/paths';

import profileImage from '../assets/inferno-castellucci-photo-de-lage.jpeg';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const performances = (await getCollection('performances'))
	.sort((a, b) => {
		const yearA = Number(a.data.year) || 0;
		const yearB = Number(b.data.year) || 0;
		return yearB - yearA;
	})
	.slice(0, 3);
---

<!doctype html>
<html lang="it">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />

		<style>
			.hero {
				display: flex;
				align-items: center;
				gap: 4rem;
				padding: 4rem 0;
				margin-bottom: 2rem;
			}

			.hero-content {
				flex: 3;
			}

			.hero-image {
				flex: 2;
				text-align: center;
				position: relative;
			}

			.hero-image img {
				width: 280px;
				height: 280px;
				object-fit: cover;
				border-radius: 50%;
				border: 6px solid var(--color-bg);
				box-shadow:
					0 0 0 1px var(--color-border),
					var(--shadow-lg);
			}

			.pub-mini-item {
				margin-bottom: 1.5rem;
				padding-bottom: 1.5rem;
				border-bottom: 1px solid var(--color-border);
			}

			.pub-mini-item:last-child {
				border-bottom: none;
				margin-bottom: 0;
			}

			.pub-title {
				font-weight: 700;
				color: var(--color-text-main);
				display: block;
				margin-bottom: 0.25rem;
				font-family: var(--font-serif);
				font-size: 1.1rem;
				text-decoration: none;
			}

			.pub-title:hover {
				color: var(--color-accent);
			}

			.pub-meta {
				font-size: 0.9rem;
				color: var(--color-text-muted);
			}

			.hero-buttons {
				display: flex;
				gap: 1rem;
				flex-wrap: wrap;
			}

			@media (max-width: 768px) {
				.hero {
					flex-direction: column-reverse;
					text-align: center;
					padding: 2rem 0;
					gap: 2rem;
				}

				.hero-image img {
					width: 200px;
					height: 200px;
				}

				.hero-buttons {
					justify-content: center;
				}
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<section class="hero">
				<div class="hero-content">
					<h1 style="margin-bottom: 0.5rem; font-size: 3rem;">
						Osservatorio "Dante e il teatro"
					</h1>

					<h2
						style="
							font-weight: 400;
							color: var(--color-text-muted);
							margin-bottom: 1.5rem;
							font-family: var(--font-sans);
							text-transform: uppercase;
							letter-spacing: 0.05em;
							font-size: 1rem;
							border-bottom: none;
							padding-bottom: 0;
							display: block;
							margin-top: 0;
						"
					>
						Progetto di ricerca<br />
						UniTo | UniSa
					</h2>

					<p
						style="
							font-size: 1.1rem;
							line-height: 1.7;
							margin-bottom: 2rem;
						"
					>
						Archivio del progetto di ricerca
						<strong>
							Dante nella contemporaneità.
							Le riscritture teatrali
						</strong>
						(PRIN 2022).
					</p>

					<div class="hero-buttons">
						<a href={url('/osservatorio')} class="btn">
							Archivio
						</a>

						<a
							href={url('/iniziative')}
							class="btn btn-outline"
						>
							Eventi
						</a>
					</div>
				</div>

				<div class="hero-image">
					<Image
						src={profileImage}
						width={280}
						height={280}
						alt="Osservatorio Dante e il teatro"
						fetchpriority="high"
						decoding="async"
					/>
				</div>
			</section>

			<hr
				style="
					margin: 3rem 0;
					border-top: 1px solid var(--color-border);
				"
			/>

			<div class="grid-2" style="gap: 4rem; margin-top: 0;">
				<section>
					<h2 style="margin-top: 0;">
						Ultimi spettacoli censiti
					</h2>

					<div class="publication-list">
						{
							performances.length > 0 ? (
								performances.map((performance) => (
									<div class="pub-mini-item">
	<a
		href={url(`/osservatorio/${performance.id}/`)}
		class="pub-title"
	>
		{performance.data.title}
	</a>

	<div class="pub-meta">
		{[
			performance.data.company || performance.data.author,
			performance.data.year,
		]
			.filter(Boolean)
			.join(', ')}
	</div>
</div>
								))
							) : (
								<p>Nessuno spettacolo censito.</p>
							)
						}
					</div>

					<div style="margin-top: 1.5rem;">
						<a
							href={url('/osservatorio')}
							style="font-weight: 600;"
						>
							Consulta l'archivio &rarr;
						</a>
					</div>
				</section>

				<section>
					<h2 style="margin-top: 0;">
						Iniziative recenti
					</h2>

					<ul style="list-style: none; padding: 0;">
						{
							posts.map((post) => (
								<li
									style="
										margin-bottom: 1.5rem;
										padding-bottom: 1.5rem;
										border-bottom: 1px dashed var(--color-border);
									"
								>
									<a
										href={url(`/iniziative/${post.id}/`)}
										style="
											display: block;
											font-family: var(--font-serif);
											font-size: 1.1rem;
											font-weight: 600;
											color: var(--color-text-main);
											margin-bottom: 0.25rem;
										"
									>
										{post.data.title}
									</a>

									<small
										style="
											color: var(--color-text-muted);
											text-transform: uppercase;
											font-size: 0.8rem;
										"
									>
										{post.data.pubDate.toLocaleDateString(
											'it-IT',
											{
												year: 'numeric',
												month: 'short',
												day: 'numeric',
											}
										)}
									</small>
								</li>
							))
						}
					</ul>

					<a
						href={url('/iniziative')}
						style="font-weight: 600;"
					>
						Vai a tutti gli eventi &rarr;
					</a>
				</section>
			</div>
		</main>

		<Footer />
	</body>
</html>